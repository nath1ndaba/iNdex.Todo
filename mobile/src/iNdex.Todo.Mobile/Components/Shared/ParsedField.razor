@* Shared/ParsedField.razor — displays a single parsed NL field *@

<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;background:rgba(255,255,255,.04)">
    <MudIcon Icon="@Icon" Style="font-size:16px;opacity:.4;flex-shrink:0" />
    <div>
        <MudText Typo="Typo.caption" Style="opacity:.35;font-size:10px;text-transform:uppercase;letter-spacing:.6px">
            @Label
        </MudText>
        <MudText Style="font-weight:600;font-size:.875rem;margin-top:1px">@Value</MudText>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter, EditorRequired] public string Icon  { get; set; } = "";
}
