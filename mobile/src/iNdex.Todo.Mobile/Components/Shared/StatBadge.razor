@* Shared/StatBadge.razor *@

<div style="text-align:center">
    <MudText Style="@($"font-size:1.05rem;font-weight:800;color:{Color};line-height:1")">@Value</MudText>
    <MudText Typo="Typo.caption" Style="opacity:.35;font-size:10px;margin-top:2px;display:block">@Label</MudText>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string Color { get; set; } = "#F1F5F9";
}
