@using Microsoft.AspNetCore.Components.Routing

<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" CloseButton="true" />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:80vh;text-align:center;padding:24px">
            <MudText Typo="Typo.h2" Style="color:#00AEEF;font-weight:900">404</MudText>
            <MudText Style="opacity:.4;margin:8px 0 24px">Page not found</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" Class="rounded-xl">Go Home</MudButton>
        </div>
    </NotFound>
</Router>
