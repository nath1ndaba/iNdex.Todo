@page "/"
@inject AppState AppState
@inject ITodoListApi ListApi
@inject ITodoTaskApi TaskApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Dashboard – iNdex Todo</PageTitle>

@if (!AppState.IsAuthenticated)
{
    <MudContainer Class="d-flex flex-column align-center justify-center" Style="min-height:70vh">
        <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Style="font-size:5rem;color:#00AEEF;opacity:.4" />
        <MudText Typo="Typo.h5" Class="mt-4 mb-2" Style="font-weight:700">Welcome to iNdex Todo</MudText>
        <MudText Typo="Typo.body1" Class="mb-6" Style="opacity:.6;text-align:center">
            Manage your tasks, stay organised, sync across all your devices.
        </MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       Href="/register" StartIcon="@Icons.Material.Filled.PersonAdd"
                       Class="rounded-xl">Get Started</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                       Href="/login" Class="rounded-xl">Sign In</MudButton>
        </MudStack>
    </MudContainer>
    return;
}

<!-- ── Greeting ──────────────────────────────────────────────────────────── -->
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:800">
            Good @_greeting,&nbsp;<span style="color:#00AEEF">@AppState.CurrentUser!.FirstName</span> 👋
        </MudText>
        <MudText Typo="Typo.body2" Style="opacity:.55">@DateTime.Now.ToString("dddd, MMMM d")</MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/lists"))"
               Class="rounded-xl">
        New List
    </MudButton>
</MudStack>

<!-- ── Stats row ─────────────────────────────────────────────────────────── -->
<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="6" sm="3">
        <StatCard Label="Lists" Value="@_lists.Count.ToString()" Icon="@Icons.Material.Filled.List" Color="#00AEEF" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Label="Total Tasks" Value="@_totalTasks.ToString()" Icon="@Icons.Material.Filled.Assignment" Color="#39D353" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Label="Completed" Value="@_completedTasks.ToString()" Icon="@Icons.Material.Filled.CheckCircle" Color="#F5A623" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Label="Pending"
                  Value="@((_totalTasks - _completedTasks).ToString())"
                  Icon="@Icons.Material.Filled.Pending"
                  Color="#EF4444" />
    </MudItem>
</MudGrid>

<!-- ── Recent lists ───────────────────────────────────────────────────────── -->
<MudText Typo="Typo.h6" Class="mb-3" Style="font-weight:700">Recent Lists</MudText>

@if (_loading)
{
    <MudGrid Spacing="3">
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_lists.Count == 0)
{
    <MudPaper Elevation="0" Class="pa-8 rounded-xl d-flex flex-column align-center" Style="border:2px dashed rgba(255,255,255,.12)">
        <MudIcon Icon="@Icons.Material.Outlined.PlaylistAdd" Style="font-size:3rem;opacity:.3" />
        <MudText Typo="Typo.body1" Class="mt-2 mb-4" Style="opacity:.5">No lists yet. Create your first one!</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick='() => Nav.NavigateTo("/lists")' Class="rounded-xl">Create List</MudButton>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var list in _lists.Take(6))
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2"
                          Class="pa-4 rounded-xl cursor-pointer mud-ripple"
                          Style="@($"border-left:4px solid {list.Color ?? "#00AEEF"};transition:transform .15s")"
                          @onclick='() => Nav.NavigateTo($"/lists/{list.Id}")'>
                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700">@list.Name</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                            @list.TaskCount tasks
                        </MudChip>
                    </MudStack>
                    @if (!string.IsNullOrEmpty(list.Description))
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                            @list.Description
                        </MudText>
                    }
                    <MudText Typo="Typo.caption" Style="opacity:.4" Class="mt-2">
                        @list.CreatedAt.ToString("MMM d")
                    </MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<TodoListResponse> _lists = [];
    private int _totalTasks;
    private int _completedTasks;
    private bool _loading = true;

    private string _greeting => DateTime.Now.Hour switch
    {
        < 12 => "morning",
        < 17 => "afternoon",
        _    => "evening"
    };

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        if (AppState.IsAuthenticated)
            await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            var resp = await ListApi.GetAllTodoListsAsync(AppState.CurrentUser!.Id);
            if (resp.IsSuccessStatusCode && resp.Content is not null)
            {
                _lists = resp.Content;
                _totalTasks = _lists.Sum(l => l.TaskCount);
                // For completed count we'd need an extra query; approximate here
                _completedTasks = 0;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
