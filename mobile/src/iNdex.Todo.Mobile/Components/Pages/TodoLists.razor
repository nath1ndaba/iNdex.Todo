@page "/lists"
@inject AppState AppState
@inject ITodoListApi ListApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>My Lists – iNdex Todo</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-5">
    <MudText Typo="Typo.h5" Style="font-weight:800">My Lists</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog"
               Class="rounded-xl">New List</MudButton>
</MudStack>

@if (_loading)
{
    <MudGrid Spacing="3">
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_lists.Count == 0)
{
    <MudPaper Elevation="0" Class="pa-10 rounded-xl d-flex flex-column align-center"
              Style="border:2px dashed rgba(255,255,255,.1)">
        <MudIcon Icon="@Icons.Material.Outlined.PlaylistAdd" Style="font-size:4rem;opacity:.25" />
        <MudText Typo="Typo.h6" Class="mt-3 mb-1" Style="opacity:.5">No lists yet</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Style="opacity:.35">Create your first todo list to get started.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog" Class="rounded-xl">Create List</MudButton>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var list in _lists)
        {
            var accent = list.Color ?? "#00AEEF";
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-5 rounded-xl"
                          Style="@($"border-left:4px solid {accent};position:relative;cursor:pointer")">

                    <!-- Click to open tasks -->
                    <div @onclick="() => Nav.NavigateTo($"/lists/{list.Id}")" style="position:absolute;inset:0;z-index:0" />

                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="mb-2">
                        <div style="z-index:1;flex:1">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700">@list.Name</MudText>
                            @if (!string.IsNullOrEmpty(list.Description))
                            {
                                <MudText Typo="Typo.caption" Style="opacity:.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                    @list.Description
                                </MudText>
                            }
                        </div>
                        <!-- Action menu -->
                        <div style="z-index:1">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                     Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                             OnClick="() => OpenEditDialog(list)">Edit</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                             IconColor="Color.Error"
                                             OnClick="() => DeleteList(list)">Delete</MudMenuItem>
                            </MudMenu>
                        </div>
                    </MudStack>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                              Style="z-index:1;position:relative" Class="mt-3">
                        <MudChip T="string" Size="Size.Small" Style="@($"background:{accent}22;color:{accent}")" Variant="Variant.Filled">
                            @list.TaskCount @(list.TaskCount == 1 ? "task" : "tasks")
                        </MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.4">
                            @list.CreatedAt.ToString("MMM d, yyyy")
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<TodoListResponse> _lists = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        if (!AppState.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var r = await ListApi.GetAllTodoListsAsync(AppState.CurrentUser!.Id);
            if (r.IsSuccessStatusCode) _lists = r.Content ?? [];
        }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<ListFormDialog>("Create List", options);
        var result  = await dialog.Result;

        if (!result!.Canceled && result.Data is CreateTodoListRequest req)
        {
            var r = await ListApi.CreateTodoListAsync(req with { OwnerId = AppState.CurrentUser!.Id });
            if (r.IsSuccessStatusCode)
            {
                Snackbar.Add("List created!", Severity.Success);
                await LoadAsync();
            }
            else Snackbar.Add("Failed to create list.", Severity.Error);
        }
    }

    private async Task OpenEditDialog(TodoListResponse list)
    {
        var parameters = new DialogParameters<ListFormDialog>
        {
            { x => x.ExistingList, list }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<ListFormDialog>("Edit List", parameters, options);
        var result  = await dialog.Result;

        if (!result!.Canceled && result.Data is CreateTodoListRequest req)
        {
            var updateReq = new UpdateTodoListRequest(req.Name, req.Description, req.Color, req.Icon);
            var r = await ListApi.UpdateTodoListAsync(list.Id, updateReq);
            if (r.IsSuccessStatusCode)
            {
                Snackbar.Add("List updated!", Severity.Success);
                await LoadAsync();
            }
            else Snackbar.Add("Failed to update list.", Severity.Error);
        }
    }

    private async Task DeleteList(TodoListResponse list)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete List",
            $"Are you sure you want to delete \"{list.Name}\"? All tasks inside will be removed.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            var r = await ListApi.DeleteTodoListAsync(list.Id);
            if (r.IsSuccessStatusCode)
            {
                Snackbar.Add("List deleted.", Severity.Info);
                await LoadAsync();
            }
            else Snackbar.Add("Failed to delete list.", Severity.Error);
        }
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
