@page "/settings"
@inject AppState AppState
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Settings – iNdex Todo</PageTitle>

<MudText Typo="Typo.h5" Style="font-weight:800" Class="mb-6">Settings</MudText>

@if (!AppState.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<!-- Profile card -->
<MudPaper Elevation="2" Class="pa-5 rounded-xl mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudAvatar Color="Color.Primary" Size="Size.Large" Style="font-size:1.5rem;font-weight:700">
            @AppState.CurrentUser!.FirstName[0]@AppState.CurrentUser.LastName[0]
        </MudAvatar>
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:700">
                @AppState.CurrentUser.FirstName @AppState.CurrentUser.LastName
            </MudText>
            <MudText Typo="Typo.body2" Style="opacity:.55">@AppState.CurrentUser.Email</MudText>
            <MudText Typo="Typo.caption" Style="opacity:.35">
                Member since @AppState.CurrentUser.CreatedAt.ToString("MMMM yyyy")
            </MudText>
        </div>
    </MudStack>
</MudPaper>

<!-- Appearance -->
<MudPaper Elevation="2" Class="pa-5 rounded-xl mb-4">
    <MudText Typo="Typo.subtitle1" Style="font-weight:700" Class="mb-3">Appearance</MudText>
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@(AppState.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                     Color="Color.Primary" />
            <MudText Typo="Typo.body1">Dark Mode</MudText>
        </MudStack>
        <MudSwitch T="bool" Value="@AppState.IsDarkMode"
                   ValueChanged="@(_ => AppState.ToggleTheme())"
                   Color="Color.Primary" />
    </MudStack>
</MudPaper>

<!-- About -->
<MudPaper Elevation="2" Class="pa-5 rounded-xl mb-4">
    <MudText Typo="Typo.subtitle1" Style="font-weight:700" Class="mb-3">About</MudText>
    <MudStack Spacing="2">
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Style="opacity:.55">App</MudText>
            <MudText Typo="Typo.body2">iNdex Todo</MudText>
        </MudStack>
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Style="opacity:.55">Version</MudText>
            <MudText Typo="Typo.body2">1.0.0</MudText>
        </MudStack>
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Style="opacity:.55">Platform</MudText>
            <MudText Typo="Typo.body2">.NET MAUI Blazor Hybrid</MudText>
        </MudStack>
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Style="opacity:.55">Real-time</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                SignalR Connected
            </MudChip>
        </MudStack>
    </MudStack>
</MudPaper>

<!-- Sign out -->
<MudButton Variant="Variant.Outlined" Color="Color.Error"
           FullWidth="true" Class="rounded-xl"
           StartIcon="@Icons.Material.Filled.Logout"
           OnClick="SignOut">Sign Out</MudButton>

@code {
    private void SignOut()
    {
        AppState.ClearUser();
        Nav.NavigateTo("/login");
    }

    protected override void OnInitialized() => AppState.OnChange += StateHasChanged;
    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
