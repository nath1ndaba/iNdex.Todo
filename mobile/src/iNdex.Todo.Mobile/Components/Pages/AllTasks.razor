@page "/tasks"
@inject AppState AppState
@inject ITodoListApi ListApi
@inject ITodoTaskApi TaskApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>All Tasks – iNdex Todo</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5" Style="font-weight:800">All Tasks</MudText>
    <MudStack Row="true" Spacing="2">
        <MudTextField @bind-Value="_search" Placeholder="Search…"
                      Variant="Variant.Outlined" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="200"
                      Style="max-width:200px" />
    </MudStack>
</MudStack>

<!-- Filter row -->
<MudChipSet T="string" @bind-SelectedValue="_filterPriority" SelectionMode="SelectionMode.SingleSelection" Class="mb-4">
    <MudChip T="string" Value="@((string?)null)" Color="Color.Default" Variant="Variant.Outlined">All</MudChip>
    <MudChip T="string" Value="Critical"  Color="Color.Error"   Variant="Variant.Outlined">🔴 Critical</MudChip>
    <MudChip T="string" Value="High"      Color="Color.Warning" Variant="Variant.Outlined">🟠 High</MudChip>
    <MudChip T="string" Value="Medium"    Color="Color.Info"    Variant="Variant.Outlined">🔵 Medium</MudChip>
    <MudChip T="string" Value="Low"       Color="Color.Success" Variant="Variant.Outlined">🟢 Low</MudChip>
</MudChipSet>

@if (_loading)
{
    <MudStack Spacing="2">
        @for (int i = 0; i < 5; i++) { <MudSkeleton Height="64px" Class="rounded-xl" /> }
    </MudStack>
}
else if (FilteredTasks.Count == 0)
{
    <MudPaper Elevation="0" Class="pa-10 rounded-xl d-flex flex-column align-center"
              Style="border:2px dashed rgba(255,255,255,.08)">
        <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size:3rem;opacity:.25" />
        <MudText Class="mt-2" Style="opacity:.4">No tasks match your filters.</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="2">
        @foreach (var task in FilteredTasks)
        {
            <TaskCard Task="task"
                      OnComplete="() => ToggleComplete(task)"
                      OnEdit="() => OpenEditDialog(task)"
                      OnDelete="() => DeleteTask(task)" />
        }
    </MudStack>
}

@code {
    private List<TodoTaskResponse> _tasks = [];
    private bool _loading = true;
    private string _search = string.Empty;
    private string? _filterPriority = null;

    private List<TodoTaskResponse> FilteredTasks => _tasks
        .Where(t => string.IsNullOrWhiteSpace(_search) ||
                    t.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (t.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(t => _filterPriority is null || t.Priority == _filterPriority)
        .OrderBy(t => t.IsCompleted)
        .ThenByDescending(t => t.Priority switch
        {
            "Critical" => 4, "High" => 3, "Medium" => 2, "Low" => 1, _ => 0
        })
        .ThenBy(t => t.DueDate ?? DateTime.MaxValue)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        if (!AppState.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var listsResp = await ListApi.GetAllTodoListsAsync(AppState.CurrentUser!.Id);
            if (!listsResp.IsSuccessStatusCode || listsResp.Content is null) return;

            var taskFetches = listsResp.Content.Select(l => TaskApi.GetTasksByListAsync(l.Id));
            var results = await Task.WhenAll(taskFetches);

            _tasks = results
                .Where(r => r.IsSuccessStatusCode && r.Content is not null)
                .SelectMany(r => r.Content!)
                .ToList();
        }
        finally { _loading = false; }
    }

    private async Task ToggleComplete(TodoTaskResponse task)
    {
        var r = await TaskApi.CompleteTaskAsync(task.Id, new(!task.IsCompleted));
        if (r.IsSuccessStatusCode && r.Content is not null)
        {
            var idx = _tasks.FindIndex(t => t.Id == task.Id);
            if (idx >= 0) _tasks[idx] = r.Content;
        }
    }

    private async Task OpenEditDialog(TodoTaskResponse task)
    {
        var parameters = new DialogParameters<TaskFormDialog> { { x => x.ExistingTask, task } };
        var dialog  = await DialogService.ShowAsync<TaskFormDialog>("Edit Task", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var result  = await dialog.Result;

        if (!result!.Canceled && result.Data is CreateTodoTaskRequest req)
        {
            var update = new UpdateTodoTaskRequest(req.Title, req.Description, req.DueDate, req.Priority, req.CategoryId);
            var r = await TaskApi.UpdateTodoTaskAsync(task.Id, update);
            if (r.IsSuccessStatusCode)
            {
                Snackbar.Add("Task updated!", Severity.Success);
                await LoadAsync();
            }
        }
    }

    private async Task DeleteTask(TodoTaskResponse task)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete Task", $"Delete \"{task.Title}\"?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            var r = await TaskApi.DeleteTodoTaskAsync(task.Id);
            if (r.IsSuccessStatusCode)
            {
                _tasks.Remove(task);
                Snackbar.Add("Task deleted.", Severity.Info);
            }
        }
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
