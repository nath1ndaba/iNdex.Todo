@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav
@inject TodoRealtimeService Realtime
@inject TokenRefreshService TokenRefresh
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="_dark" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" CloseButton="true" />
<MudSnackbarProvider />

@if (AppState.IsAuthenticated)
{
    <header class="app-header">
        <div style="display:flex;align-items:center;gap:10px">
            <img src="logo.png" alt="iNdex" style="height:30px;width:30px;object-fit:contain;border-radius:8px" />
            <div>
                <span style="font-weight:900;font-size:1rem;color:#00AEEF">iNdex</span>
                <span style="font-weight:900;font-size:1rem;color:#F5A623"> Todo</span>
            </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
            <ConnectionStatus />
            <MudIconButton Icon="@(AppState.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Default" Size="Size.Small"
                           OnClick="AppState.ToggleTheme" />
            <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#0050A0,#00AEEF);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:white;cursor:pointer"
                 @onclick='() => Nav.NavigateTo("/settings")'>
                @AppState.CurrentUser!.FirstName[0]@AppState.CurrentUser.LastName[0]
            </div>
        </div>
    </header>

    <div class="page-content">@Body</div>

    <nav class="bottom-nav">
        <NavButton Href="/" Icon="@Icons.Material.Filled.Dashboard" Label="Home" Active="@IsActive("/", exact: true)" />
        <NavButton Href="/lists" Icon="@Icons.Material.Filled.CheckCircleOutline" Label="Tasks" Active="@IsActive("/lists")" />
        <NavButton Href="/tickets" Icon="@Icons.Material.Filled.ConfirmationNumber" Label="Tickets" Active="@IsActive("/tickets")" />
        <NavButton Href="/timelog" Icon="@Icons.Material.Filled.Timer" Label="Time" Active="@IsActive("/timelog")" />
        <NavButton Href="/settings" Icon="@Icons.Material.Filled.Person" Label="Me" Active="@IsActive("/settings")" />
    </nav>
}
else
{
    @Body
}

@code {
    private bool _dark = true;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#00AEEF",
            Secondary = "#39D353",
            Tertiary = "#F5A623",

            Background = "#070B14",

            AppbarBackground = "#070B14",
            DrawerBackground = "#070B14",

            Surface = "#111827",

            TextPrimary = "#F1F5F9",
            TextSecondary = "#64748B"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Inter", "system-ui", "sans-serif"] }
        },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "12px" }
    };

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnStateChanged;
        _dark = AppState.IsDarkMode;
        TokenRefresh.Start();
        if (AppState.IsAuthenticated)
            await Realtime.ConnectAsync(AppState.CurrentUser!.Id);
    }

    private async void OnStateChanged()
    {
        _dark = AppState.IsDarkMode;
        if (AppState.IsAuthenticated)
            await Realtime.ConnectAsync(AppState.CurrentUser!.Id);
        await InvokeAsync(StateHasChanged);
    }

    private bool IsActive(string href, bool exact = false)
    {
        var path = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        return exact ? path == href : path.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose() => AppState.OnChange -= OnStateChanged;
}
